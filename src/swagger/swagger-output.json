    "/aluguel": {
      "get": {
        "tags": [
          "Aluguel"
        ],
        "summary": "Listar todos os aluguéis",
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "tags": [
          "Aluguel"
        ],
        "summary": "Realizar retirada de veículo",
        "description": "Cria um novo registro de aluguel com status \"aberto\". Esta operação valida se o carro e o cliente existem e se o veículo está com status \"disponivel\". Após a criação, o status do veículo é alterado automaticamente para \"alugado\".",
        "parameters": [
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "pessoaId": {
                    "example": "any"
                  },
                  "carroId": {
                    "example": "any"
                  },
                  "agenciaRetiradaId": {
                    "example": "any"
                  },
                  "km_inicial": {
                    "example": "any"
                  },
                  "data_retirada": {
                    "example": "any"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/aluguel/finalizar/{id}": {
      "put": {
        "tags": [
          "Aluguel"
        ],
        "summary": "Registrar devolução de veículo",
        "description": "Encerra um contrato de aluguel ativo. A rota calcula (ou recebe) o KM final e o valor total. Ao finalizar, o status do contrato muda para \"finalizado\", a agência de devolução é registrada e o veículo retorna ao status \"disponivel\", atualizando sua quilometragem atual.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "authorization",
            "in": "header",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "agenciaDevolucaoId": {
                    "example": "any"
                  },
                  "km_final": {
                    "example": "any"
                  },
                  "valor_total": {
                    "example": "any"
                  }
                }
              }
            }
          }
        }
      }
